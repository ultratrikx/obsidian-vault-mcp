# Absolute path to your Obsidian vault directory
VAULT_PATH=/home/clanker/vault

# Directory to store QMD search index (SQLite db + model cache)
QMD_DB_PATH=/home/clanker/obsidian_server/qmd-index/vault.db

# MCP server port when running in HTTP mode (default: 3000)
MCP_PORT=3000

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info
